# NexusLearn Backend Configuration
# Copy this to DeepTutor.env and fill in values

# ── LLM Provider (choose one) ──────────────────────
# Option 1: Ollama (FREE local LLM - recommended)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2

# Option 2: Claude API (paid)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_key_here
# LLM_MODEL=claude-3-5-haiku-20241022

# Option 3: OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_key_here
# LLM_MODEL=gpt-4o-mini

# ── Web Search (optional - enables internet fetching) ──
# All free-tier options:
# SEARCH_PROVIDER=perplexity   (needs key)
# SEARCH_PROVIDER=tavily       (needs key)
# Leave empty to disable web search

# ── TTS (optional - browser TTS works without this) ──
# TTS_MODEL=
# TTS_API_KEY=
# TTS_URL=

# ── Database ─────────────────────────────────────────
# SQLite by default (no config needed)
# DATABASE_URL=sqlite:///./data/nexuslearn.db
